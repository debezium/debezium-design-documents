      "isDeleted": false,
      "boundElements": null,
      "updated": 1780330525027,
      "link": null,
      "locked": false,
      "text": "@Transactional(REQUIRES_NEW)\nPESSIMISTIC_WRITE locks\nSort IDs --> Lock all hosts\nDeployStrategy --> Select host\nMAX(port)+1 --> Allocate port\nTX commits --> locks released",
      "fontSize": 36,
      "fontFamily": 5,
      "textAlign": "left",
